// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String
  price         Float
  originalPrice Float?
  quantity      Int
  category      String   @default("All")
  badge         String?
  features      String[]
  images        String[]
  videos        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id                String      @id @default(uuid())
  cashfreeOrderId   String      @unique
  status            String      @default("PENDING") // PENDING | PAID | FAILED | SHIPPED | REFUNDED
  customerName      String
  customerEmail     String
  customerPhone     String
  address           String
  city              String
  state             String
  pincode           String
  subtotal          Float
  deliveryFee       Float
  total             Float
  items             OrderItem[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName String
  price       Float
  quantity    Int
  image       String
}
