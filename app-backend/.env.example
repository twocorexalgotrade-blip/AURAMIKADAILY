PORT=4000
NODE_ENV=development

# Firebase Admin SDK — OPTION A (recommended for Render/cloud): paste the entire JSON file content
# Go to Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then paste the whole JSON here (newlines are handled automatically by JSON.parse)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Admin SDK — OPTION B: three separate fields (only used if FIREBASE_SERVICE_ACCOUNT_JSON is not set)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cashfree — from Cashfree Dashboard → Credentials
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=TEST   # TEST | PROD

# OpenAI — for AI Stylist
OPENAI_API_KEY=

# Comma-separated Firebase UIDs with admin access to update order statuses
ADMIN_UIDS=

# PostgreSQL connection string (Render / any Postgres host)
DATABASE_URL=
