{
  "name": "auramika-app-backend",
  "version": "2.0.0",
  "description": "AURAMIKA app backend — REST API for the Flutter app",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
